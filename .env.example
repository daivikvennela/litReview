# Copy this file to .env and fill in your keys.

# Required for LLM features (chat/reviews):
OPENROUTER_API_KEY=sk-or-v1-...

# Optional (defaults to http://localhost:8070 in app settings):
GROBID_URL=http://localhost:8070

# OpenDataLoader (default PDF parser) — Java 11+ required. Hybrid backend (optional, for OCR/tables):
# pip install "opendataloader-pdf[hybrid]" && opendataloader-pdf-hybrid --port 5002
# Settings UI stores: opendataloader_hybrid_url (default http://localhost:5002), toggles, etc.

# Optional: backend port if 3456 (or another) is already in use — must match for `npm run dev` (Vite reads this too).
# PORT=37891
